{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "chmod 777 *": "deny",
      "git push --force *": "deny",
      "git reset --hard *": "deny",
      "git push *": "ask"
    }
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "claude-code", "--project-from-cwd", "--open-web-dashboard", "false"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "mcp-docker": {
      "type": "local",
      "command": ["docker", "mcp", "gateway", "run"],
      "enabled": true
    }
  },
  "agent": {
    "opus": {
      "description": "Opus 4.6 for complex reasoning, architecture decisions, and multi-file refactors",
      "mode": "subagent",
      "model": "anthropic/claude-opus-4-6"
    },
    "codex": {
      "description": "Codex 5.3 for code analysis, implementation, and review",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex"
    }
  }
}
